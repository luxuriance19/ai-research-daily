{
  "name": "frontier-signals-ai-daily",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --experimental-loader ./tests/cloudflare-loader.mjs --test tests/*.test.mjs",
    "audit:mechanisms": "node automation/run-mechanism-watch.mjs",
    "gate:mechanisms": "node automation/run-and-verify-mechanism-watch.mjs",
    "probe:source-candidates": "node automation/run-candidate-source-probe.mjs",
    "gate:source-candidates": "node automation/run-and-verify-candidate-source-probe.mjs",
    "probe:tech-discovery": "node automation/run-tech-discovery-probe.mjs",
    "gate:tech-discovery": "node automation/run-and-verify-tech-discovery-probe.mjs",
    "probe:model-compute-sources": "node automation/run-model-compute-source-probe.mjs",
    "gate:model-compute-sources": "node automation/run-and-verify-model-compute-source-probe.mjs",
    "audit:source-diligence": "node automation/run-source-diligence.mjs",
    "gate:source-diligence": "node automation/run-and-verify-source-diligence.mjs",
    "prepare:semantic-review": "node automation/run-semantic-review-dossiers.mjs",
    "gate:semantic-review": "node automation/run-and-verify-semantic-review-dossiers.mjs",
    "audit:source-readiness": "node automation/run-source-promotion-readiness.mjs",
    "gate:source-readiness": "node automation/run-and-verify-source-promotion-readiness.mjs",
    "scout:evidence-gaps": "node automation/run-evidence-gap-scout.mjs",
    "replay:source-acceptance": "node automation/replay-source-acceptance.mjs",
    "replay:model-compute-sources": "node automation/replay-model-compute-source-policy.mjs",
    "replay:unified-top3": "node automation/unified-top3-replay.mjs",
    "gate:unified-top3": "node automation/run-and-verify-unified-top3.mjs",
    "dossier:top3-evidence": "node automation/top3-evidence-dossier.mjs",
    "gate:top3-evidence": "node automation/run-and-verify-top3-evidence-dossier.mjs",
    "sync:top3-site": "node automation/top3-site-data.mjs",
    "sync:formula-assets": "node automation/formula-site-data.mjs && python3 scripts/render_formula_assets.py --manifest data/formula-assets-latest.json --output-dir public/formulas",
    "sync:mechanism-radar-site": "node automation/mechanism-radar-site-data.mjs",
    "sync:source-quality-site": "node automation/source-quality-site-data.mjs",
    "sync:source-role-review": "node automation/source-role-review.mjs",
    "check:daily-health": "node automation/daily-health-check.mjs",
    "daily:fast": "node automation/fast-daily-pipeline.mjs",
    "daily:fast:reuse": "node automation/fast-daily-pipeline.mjs --reuse-discovery --skip-supplement",
    "verify:source-candidates": "node automation/verify-candidate-source-probe.mjs work/candidate-source-probe/audit.json",
    "verify:tech-discovery": "node automation/verify-tech-discovery-probe.mjs work/tech-discovery-probe/audit.json",
    "verify:model-compute-probe": "node automation/verify-model-compute-source-probe.mjs work/model-compute-source-probe/audit.json",
    "verify:source-diligence": "node automation/verify-source-diligence.mjs work/source-diligence/coverage.json",
    "verify:semantic-review": "node automation/verify-semantic-review-dossiers.mjs work/semantic-review-dossiers/dossier.json",
    "verify:source-readiness": "node automation/verify-source-promotion-readiness.mjs work/source-promotion-readiness/readiness.json",
    "verify:evidence-scout": "node automation/verify-evidence-gap-scout.mjs work/evidence-gap-scout/audit.json",
    "verify:model-compute-sources": "node automation/verify-model-compute-source-replay.mjs work/model-compute-source-replay/audit.json",
    "verify:unified-top3": "node automation/verify-unified-top3-replay.mjs work/unified-top3-replay/audit.json",
    "verify:top3-evidence": "node automation/verify-top3-evidence-dossier.mjs work/top3-evidence-dossier/audit.json",
    "verify:mechanisms": "node automation/verify-mechanism-audit.mjs work/mechanism-watch/audit.json",
    "recover:mechanism-window": "node automation/recover-mechanism-window.mjs",
    "export:static": "node automation/export-static.mjs",
    "security:secrets": "node automation/check-no-secrets.mjs --all",
    "security:secrets:history": "node automation/check-no-secrets.mjs --history",
    "security:secrets:self-test": "node automation/check-no-secrets.mjs --self-test",
    "ensure:cloudflare-pages": "node automation/ensure-cloudflare-pages.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "fast-xml-parser": "^5.10.1",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
